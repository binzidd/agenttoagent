# ─────────────────────────────────────────────────────────────────────────────
# Austral Agent Stack – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Anthropic API ────────────────────────────────────────────────────────────
# Required for chat and the ClaudeAdvisor synthesis agent.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── NSW FuelCheck API ─────────────────────────────────────────────────────────
# Register free at: https://api.nsw.gov.au/Product/Index/22
# Leave blank to use realistic synthetic fallback data.
NSW_FUELCHECK_API_KEY=
NSW_FUELCHECK_API_SECRET=

# ── Home Configuration ────────────────────────────────────────────────────────
HOME_LAT=-33.93
HOME_LON=150.82
HOME_POSTCODE=2179
SOLAR_SYSTEM_KW=9.0
BATTERY_CAPACITY_KWH=9.0
FEED_IN_TARIFF_CENTS=5.0        # c/kWh paid for solar exported to grid

# ── Motorcycle Configuration ──────────────────────────────────────────────────
BIKE_CONSUMPTION_L_100KM=7.5
BIKE_TANK_FILL_LITRES=15.0
PREFERRED_FUEL_TYPE=P98

# ── CORS / Server ────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
