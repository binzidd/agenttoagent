# ─────────────────────────────────────────────────────────────────────────────
# Austral Agent Stack – Streamlit Dashboard container
#
# Build:   docker build -f Dockerfile.streamlit -t austral-dashboard .
# Run:     docker run -p 8501:8501 --env-file backend/.env austral-dashboard
# ─────────────────────────────────────────────────────────────────────────────

FROM python:3.10-slim

EXPOSE 8501

# Non-root user
RUN useradd -m -u 1000 appuser

WORKDIR /app

COPY backend/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY backend/ .

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

USER appuser

# Disable Streamlit's file-watcher (not needed in prod) and browser auto-open
CMD ["streamlit", "run", "dashboard.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true", \
     "--browser.gatherUsageStats=false"]
